# URL base del Backend Spring Boot
# Para pruebas locales en navegador usa localhost
VITE_API_BASE_URL=http://localhost:8080/api

# Si vas a compilar la app para Android e instalarla en tu dispositivo físico,
# descomenta la línea de abajo y pon tu IP privada (ej: 192.168.1.50)
# VITE_API_BASE_URL=http://192.168.1.50:8080/api

# Si vas a usar el emulador nativo de Android Studio,
# descomenta la línea de abajo:
# VITE_API_BASE_URL=http://10.0.2.2:8080/api
